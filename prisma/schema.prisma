generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Show {
  id              String   @id @default(cuid())
  slug            String   @unique
  date            DateTime
  city            String
  country         String
  venue           String
  notes           String?

  capacity        Int
  ticketPrice     Float
  ticketSales     Int      @default(0)
  metaSpend       Float    @default(0)

  venueHire       Float    @default(0)
  production      Float    @default(0)
  hotelPetrolMisc Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TourSettings {
  id              String   @id @default("main")
  plannedAdBudget Float    @default(12000)
  blendedCpt      Float    @default(8)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id         String   @id @default(cuid())
  domain     String
  status     String
  message    String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
}