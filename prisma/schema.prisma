generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Show {
  id              String   @id @default(cuid())
  slug            String   @unique
  date            DateTime
  city            String
  country         String
  venue           String
  notes           String?

  capacity        Int
  ticketPrice     Float
  ticketSales     Int      @default(0)
  metaSpend       Float    @default(0)

  venueHire       Float    @default(0)
  production      Float    @default(0)
  hotelPetrolMisc Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TourSettings {
  id              String   @id @default("main")
  plannedAdBudget Float    @default(12000)
  blendedCpt      Float    @default(8)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ShopifyOrder {
  id                       String   @id
  orderNumber              String?
  name                     String?
  createdAt                DateTime
  processedAt              DateTime?
  currency                 String?
  financialStatus          String?
  fulfillmentStatus        String?
  displayFulfillmentStatus String?
  email                    String?
  customerFirstName        String?
  customerLastName         String?
  customerCountry          String?
  customerCountryCode      String?
  subtotalPrice            Float    @default(0)
  totalDiscounts           Float    @default(0)
  totalShipping            Float    @default(0)
  totalTax                 Float    @default(0)
  totalPrice               Float    @default(0)
  tags                     String?
  rawJson                  Json?
  syncedAt                 DateTime @default(now())
  lineItems                ShopifyOrderLineItem[]

  @@index([createdAt])
  @@index([customerCountryCode])
}

model ShopifyOrderLineItem {
  id               String   @id
  shopifyOrderId   String
  title            String
  sku              String?
  variantTitle     String?
  quantity         Int      @default(1)
  price            Float    @default(0)
  vendor           String?
  productType      String?
  requiresShipping Boolean?
  taxable          Boolean?
  rawJson          Json?

  shopifyOrder ShopifyOrder @relation(fields: [shopifyOrderId], references: [id], onDelete: Cascade)

  @@index([shopifyOrderId])
  @@index([sku])
  @@index([title])
}

model ShopifyCustomer {
  id               String   @id
  createdAt        DateTime
  updatedAtShopify DateTime?
  email            String?
  firstName        String?
  lastName         String?
  ordersCount      Int      @default(0)
  totalSpent       Float    @default(0)
  country          String?
  countryCode      String?
  tags             String?
  rawJson          Json?
  syncedAt         DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([countryCode])
}

model MetaDaily {
  date        DateTime @id
  spend       Float    @default(0)
  purchases   Int      @default(0)
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id         String   @id @default(cuid())
  domain     String
  status     String
  message    String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
}